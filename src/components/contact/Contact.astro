<section id="contact" class="section-padding bg-gradient-to-b from-bg-primary to-bg-secondary">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <!-- Section Title -->
    <div class="mb-10 reveal">
      <h2 class="font-heading text-[clamp(1.75rem,3.5vw,2.75rem)] font-bold leading-[1.2] tracking-[-0.01em] text-text-primary">
        Контакты
      </h2>
      <span class="section-underline-left"></span>
    </div>

    <!-- Two column layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <!-- Left: Contact Info -->
      <div class="space-y-6 reveal">
        <!-- Address -->
        <div class="flex items-start gap-3">
          <div class="shrink-0 w-5 h-5 text-brand-gold mt-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p class="font-body text-[1rem] text-text-primary">
              г. Энгельс, ул. Московская, д. 15
            </p>
            <a href="https://yandex.ru/maps/?ll=46.0,51.5&z=16&pt=46.0,51.5,pm2dol" target="_blank" rel="noopener noreferrer" class="font-body text-[0.8rem] text-brand-gold hover:text-brand-gold-light transition-colors no-underline">
              Открыть на Яндекс.Картах
            </a>
          </div>
        </div>

        <!-- Phone -->
        <div class="flex items-center gap-3">
          <div class="shrink-0 w-5 h-5 text-brand-gold">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <a href="tel:+78453567890" class="font-body text-[1.125rem] font-medium text-text-primary hover:text-brand-gold transition-colors no-underline">
            +7 (8453) 56-78-90
          </a>
        </div>

        <!-- Email -->
        <div class="flex items-center gap-3">
          <div class="shrink-0 w-5 h-5 text-brand-gold">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <a href="mailto:info@vegas-barbershop.ru" class="font-body text-[1rem] text-text-primary hover:text-brand-gold transition-colors no-underline">
            info@vegas-barbershop.ru
          </a>
        </div>

        <!-- Hours -->
        <div class="pt-2">
          <h3 class="font-body text-[0.75rem] font-semibold tracking-[0.08em] text-brand-gold uppercase mb-3">
            Часы работы
          </h3>
          <div class="space-y-2">
            <div class="flex items-center justify-between max-w-[280px]">
              <span class="font-body text-[0.875rem] text-brand-gray-dark">Пн–Пт</span>
              <span class="font-body text-[0.875rem] text-text-primary">09:00 – 20:00</span>
            </div>
            <div class="flex items-center justify-between max-w-[280px]">
              <span class="font-body text-[0.875rem] text-brand-gray-dark">Сб</span>
              <span class="font-body text-[0.875rem] text-text-primary">09:00 – 19:00</span>
            </div>
            <div class="flex items-center justify-between max-w-[280px]">
              <span class="font-body text-[0.875rem] text-brand-gray-dark">Вс</span>
              <span class="font-body text-[0.875rem] text-text-primary">10:00 – 18:00</span>
            </div>
          </div>
        </div>

        <!-- Social Row -->
        <div class="flex items-center gap-4 pt-2">
          <a href="https://instagram.com/" target="_blank" rel="noopener noreferrer" class="text-brand-gray hover:text-brand-gold transition-colors" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
