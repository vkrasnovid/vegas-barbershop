---
import BaseLayout from '@/components/layout/BaseLayout.astro';

// Meta refresh for auto-redirect after 10s
const metaRefresh = '0; url=/';
---

<BaseLayout title="Спасибо за запись! — VEGAS Барбершоп" description="Ваша заявка принята. Мы свяжемся с вами для подтверждения.">
  <head>
    <meta http-equiv="refresh" content={metaRefresh} />
  </head>

  <main class="min-h-screen bg-brand-black flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <!-- Success icon -->
      <div class="text-brand-gold mb-6 flex justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </div>

      <h1 class="font-heading text-[clamp(1.75rem,3vw,2.5rem)] font-bold text-brand-gold mb-4">
        Спасибо за запись!
      </h1>

      <p class="font-body text-[1rem] text-brand-gray mb-8">
        Мы свяжемся с вами для подтверждения в ближайшее время.
      </p>

      <a href="/" class="inline-flex items-center gap-2 font-body text-[0.875rem] font-medium text-brand-gold hover:text-brand-gold-light transition-colors no-underline">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Вернуться на главную
      </a>

      <p class="font-body text-[0.75rem] text-brand-gray-dark mt-8">
        Автоматический возврат через 10 секунд...
      </p>
    </div>
  </main>
</BaseLayout>
