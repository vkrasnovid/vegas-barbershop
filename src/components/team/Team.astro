---
import { barbers } from './team.data';
import BarberCard from './BarberCard.astro';
---

<section id="team" class="section-padding bg-bg-primary">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <!-- Section Title -->
    <div class="text-center mb-12 reveal">
      <h2 class="font-heading text-[clamp(1.75rem,3.5vw,2.75rem)] font-bold leading-[1.2] tracking-[-0.01em] text-text-primary">
        Наши барберы
      </h2>
      <span class="section-underline"></span>
      <p class="font-body text-[clamp(0.875rem,1vw,1rem)] text-text-secondary max-w-[600px] mx-auto mt-4">
        Мастера своего дела с опытом от 5 лет
      </p>
    </div>

    <!-- Barber Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {
        barbers.map((barber, index) => (
          <div class="even:translate-y-0 lg:even:translate-y-4">
            <BarberCard barber={barber} index={index} />
          </div>
        ))
      }
    </div>
  </div>
</section>
