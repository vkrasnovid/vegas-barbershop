---
import { services } from '../services/services.data';
import { barbers } from '../team/team.data';
---

<section id="booking" class="section-padding bg-gradient-to-b from-brand-black to-brand-dark">
  <div class="max-w-[520px] mx-auto px-4">
    <!-- Section Title -->
    <div class="text-center mb-8 reveal">
      <h2 class="font-heading text-[clamp(1.75rem,3.5vw,2.75rem)] font-bold leading-[1.2] tracking-[-0.01em] text-brand-white">
        Запись онлайн
      </h2>
      <span class="section-underline"></span>
      <p class="font-body text-[0.875rem] text-brand-gray max-w-[420px] mx-auto mt-4">
        Заполните форму, и мы подтвердим запись в Telegram в течение часа
      </p>
    </div>

    <!-- Form -->
    <form id="booking-form" class="bg-brand-surface border border-brand-gold/10 rounded-[12px] p-6 md:p-8 space-y-5 reveal" novalidate>
      <!-- Name -->
      <div>
        <label for="booking-name" class="block font-body text-[0.75rem] font-semibold tracking-[0.08em] text-brand-gold uppercase mb-1.5">Ваше имя</label>
        <input
          type="text"
          id="booking-name"
          name="name"
          placeholder="Иван"
          required
          minlength="2"
          maxlength="50"
          pattern="^[а-яёА-ЯЁa-zA-Z\s-]+$"
          class="w-full px-4 py-3 bg-brand-black text-brand-white text-[1rem] border border-brand-gray-light/50 rounded-[4px] placeholder:text-brand-gray-dark focus:border-brand-gold focus:shadow-[0_0_0_3px_rgba(201,168,76,0.15)] focus:outline-none transition-all duration-200"
        />
        <p class="error-message mt-1 text-error text-[0.8rem] hidden" data-for="name"></p>
      </div>

      <!-- Phone -->
      <div>
        <label for="booking-phone" class="block font-body text-[0.75rem] font-semibold tracking-[0.08em] text-brand-gold uppercase mb-1.5">Телефон</label>
        <input
          type="tel"
          id="booking-phone"
          name="phone"
          placeholder="+7 (927) 123-45-67"
          required
          class="w-full px-4 py-3 bg-brand-black text-brand-white text-[1rem] border border-brand-gray-light/50 rounded-[4px] placeholder:text-brand-gray-dark focus:border-brand-gold focus:shadow-[0_0_0_3px_rgba(201,168,76,0.15)] focus:outline-none transition-all duration-200"
        />
        <p class="error-message mt-1 text-error text-[0.8rem] hidden" data-for="phone"></p>
      </div>

      <!-- Service -->
      <div>
        <label for="booking-service" class="block font-body text-[0.75rem] font-semibold tracking-[0.08em] text-brand-gold uppercase mb-1.5">Услуга</label>
        <div class="relative">
          <select
            id="booking-service"
            name="service"
            required
            class="w-full px-4 py-3 bg-brand-black text-brand-white text-[1rem] border border-brand-gray-light/50 rounded-[4px] focus:border-brand-gold focus:shadow-[0_0_0_3px_rgba(201,168,76,0.15)] focus:outline-none transition-all duration-200 appearance-none cursor-pointer pr-10"
          >
            <option value="" disabled selected>Выберите услугу</option>
            {
              services.map((s) => (
                <option value={s.name}>{s.name} — {s.price.toLocaleString('ru-RU')} ₽</option>
              ))
            }
          </select>
          <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-brand-gray">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
        </div>
        <p class="error-message mt-1 text-error text-[0.8rem] hidden" data-for="service"></p>
      </div>

      <!-- Barber -->
      <div>
        <label for="booking-barber" class="block font-body text-[0.75rem] font-semibold tracking-[0.08em] text-brand-gold uppercase mb-1.5">Барбер</label>
        <div class="relative">
          <select
            id="booking-barber"
            name="barber"
            class="w-full px-4 py-3 bg-brand-black text-brand-white text-[1rem] border border-brand-gray-light/50 rounded-[4px] focus:border-brand-gold focus:shadow-[0_0_0_3px_rgba(201,168,76,0.15)] focus:outline-none transition-all duration-200 appearance-none cursor-pointer pr-10"
          >
            <option value="Любой">Любой</option>
            {
              barbers.map((b) => (
                <option value={b.name}>{b.name}</option>
              ))
            }
          </select>
          <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-brand-gray">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
        </div>
      </div>

      <!-- Date + Time row -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="booking-date" class="block font-body text-[0.75rem] font-semibold tracking-[0.08em] text-brand-gold uppercase mb-1.5">Дата</label>
          <input
            type="date"
            id="booking-date"
            name="date"
            required
            class="w-full px-4 py-3 bg-brand-black text-brand-white text-[1rem] border border-brand-gray-light/50 rounded-[4px] focus:border-brand-gold focus:shadow-[0_0_0_3px_rgba(201,168,76,0.15)] focus:outline-none transition-all duration-200"
          />
          <p class="error-message mt-1 text-error text-[0.8rem] hidden" data-for="date"></p>
        </div>
        <div>
          <label for="booking-time" class="block font-body text-[0.75rem] font-semibold tracking-[0.08em] text-brand-gold uppercase mb-1.5">Время</label>
          <div class="relative">
            <select
              id="booking-time"
              name="time"
              required
              class="w-full px-4 py-3 bg-brand-black text-brand-white text-[1rem] border border-brand-gray-light/50 rounded-[4px] focus:border-brand-gold focus:shadow-[0_0_0_3px_rgba(201,168,76,0.15)] focus:outline-none transition-all duration-200 appearance-none cursor-pointer pr-10"
            >
              <option value="" disabled selected>Выберите</option>
              {
                Array.from({ length: 23 }, (_, i) => {
                  const hour = 9 + Math.floor(i / 2);
                  const minute = i % 2 === 0 ? '00' : '30';
                  const time = `${String(hour).padStart(2, '0')}:${minute}`;
                  return <option value={time}>{time}</option>;
                })
              }
            </select>
            <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-brand-gray">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>
          <p class="error-message mt-1 text-error text-[0.8rem] hidden" data-for="time"></p>
        </div>
      </div>

      <!-- Message -->
      <div>
        <label for="booking-message" class="block font-body text-[0.75rem] font-semibold tracking-[0.08em] text-brand-gold uppercase mb-1.5">
          Комментарий <span class="text-brand-gray-dark font-normal normal-case">(необязательно)</span>
        </label>
        <textarea
          id="booking-message"
          name="message"
          rows="3"
          maxlength="200"
          placeholder="Пожелания по стрижке..."
          class="w-full px-4 py-3 bg-brand-black text-brand-white text-[1rem] border border-brand-gray-light/50 rounded-[4px] placeholder:text-brand-gray-dark focus:border-brand-gold focus:shadow-[0_0_0_3px_rgba(201,168,76,0.15)] focus:outline-none transition-all duration-200 resize-none"
        ></textarea>
        <p class="error-message mt-1 text-error text-[0.8rem] hidden" data-for="message"></p>
      </div>

      <!-- Submit -->
      <button
        type="submit"
        id="booking-submit"
        class="w-full flex items-center justify-center gap-2 bg-brand-gold text-brand-black text-[1rem] font-semibold px-6 py-4 rounded-full hover:bg-brand-gold-light hover:shadow-glow-lg active:bg-brand-gold-dark transition-all duration-200 disabled:opacity-70 disabled:cursor-not-allowed"
      >
        <svg id="submit-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M8 6V4"/><path d="M16 6V4"/><rect width="18" height="16" x="3" y="8" rx="2"/><path d="M3 13h18"/></svg>
        <span id="submit-text">Записаться</span>
        <svg id="submit-spinner" class="hidden animate-spin" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
      </button>

      <!-- Status -->
      <div id="form-status" class="hidden text-center font-body text-[0.875rem]"></div>

      <!-- Privacy note -->
      <p class="text-center font-body text-[0.75rem] text-brand-gray-dark">
        Нажимая «Записаться», вы соглашаетесь с обработкой персональных данных
      </p>
    </form>
  </div>
</section>

<script>
  class BookingFormHandler {
    form: HTMLFormElement;
    submitBtn: HTMLButtonElement;
    submitText: HTMLElement;
    submitSpinner: HTMLElement;
    submitIcon: HTMLElement;
    statusEl: HTMLElement;

    constructor() {
      this.form = document.getElementById('booking-form') as HTMLFormElement;
      this.submitBtn = document.getElementById('booking-submit') as HTMLButtonElement;
      this.submitText = document.getElementById('submit-text')!;
      this.submitSpinner = document.getElementById('submit-spinner')!;
      this.submitIcon = document.getElementById('submit-icon')!;
      this.statusEl = document.getElementById('form-status')!;

      this.initPhoneMask();
      this.initDateRestrictions();
      this.initValidation();

      this.form.addEventListener('submit', (e) => this.handleSubmit(e));
    }

    initPhoneMask() {
      const phoneInput = document.getElementById('booking-phone') as HTMLInputElement;
      phoneInput.addEventListener('input', () => {
        let value = phoneInput.value.replace(/\D/g, '');
        if (!value.startsWith('7')) value = '7' + value;
        value = value.slice(0, 11);
        let formatted = '+7';
        if (value.length > 1) formatted += ' (' + value.slice(1, 4);
        if (value.length >= 5) formatted += ') ' + value.slice(4, 7);
        if (value.length >= 8) formatted += '-' + value.slice(7, 9);
        if (value.length >= 10) formatted += '-' + value.slice(9, 11);
        phoneInput.value = formatted;
      });
    }

    initDateRestrictions() {
      const dateInput = document.getElementById('booking-date') as HTMLInputElement;
      const today = new Date();
      const yyyy = today.getFullYear();
      const mm = String(today.getMonth() + 1).padStart(2, '0');
      const dd = String(today.getDate()).padStart(2, '0');
      dateInput.min = `${yyyy}-${mm}-${dd}`;

      const maxDate = new Date(today);
      maxDate.setDate(maxDate.getDate() + 30);
      const maxYyyy = maxDate.getFullYear();
      const maxMm = String(maxDate.getMonth() + 1).padStart(2, '0');
      const maxDd = String(maxDate.getDate()).padStart(2, '0');
      dateInput.max = `${maxYyyy}-${maxMm}-${maxDd}`;
    }

    initValidation() {
      const inputs = this.form.querySelectorAll('input, select, textarea');
      inputs.forEach((input) => {
        input.addEventListener('blur', () => this.validateField(input as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement));
        input.addEventListener('input', () => this.clearFieldError(input as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement));
      });
    }

    clearFieldError(el: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement) {
      const errorEl = document.querySelector(`.error-message[data-for="${el.name}"]`);
      if (errorEl) {
        errorEl.classList.add('hidden');
      }
      el.classList.remove('border-error', 'focus:border-error');
    }

    validateField(el: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement): boolean {
      const name = el.name;
      const value = el.value.trim();
      let error = '';

      if (name === 'name') {
        if (!value) error = 'Укажите ваше имя';
        else if (value.length < 2) error = 'Имя должно содержать минимум 2 символа';
        else if (value.length > 50) error = 'Имя не должно превышать 50 символов';
        else if (/[0-9]/.test(value)) error = 'Имя не должно содержать цифры';
      } else if (name === 'phone') {
        const digits = value.replace(/\D/g, '');
        if (!digits) error = 'Укажите номер телефона';
        else if (digits.length < 11) error = 'Номер должен содержать 11 цифр';
      } else if (name === 'service') {
        if (!value) error = 'Выберите услугу';
      } else if (name === 'date') {
        if (!value) error = 'Укажите дату';
      } else if (name === 'time') {
        if (!value) error = 'Укажите время';
      } else if (name === 'message') {
        if (value.length > 200) error = 'Комментарий не должен превышать 200 символов';
      }

      const errorEl = document.querySelector(`.error-message[data-for="${name}"]`);
      if (error && errorEl) {
        errorEl.textContent = error;
        errorEl.classList.remove('hidden');
        el.classList.add('border-error');
        return false;
      }

      if (errorEl) errorEl.classList.add('hidden');
      el.classList.remove('border-error');
      return true;
    }

    validateAll(): boolean {
      let isValid = true;
      const fields = ['name', 'phone', 'service', 'date', 'time', 'message'];
      fields.forEach((fieldName) => {
        const el = this.form.querySelector(`[name="${fieldName}"]`) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
        if (el && !this.validateField(el)) {
          isValid = false;
        }
      });
      return isValid;
    }

    async handleSubmit(e: Event) {
      e.preventDefault();

      if (!this.validateAll()) {
        // Focus first error field
        const firstError = this.form.querySelector('.error-message:not(.hidden)');
        if (firstError) {
          const fieldName = firstError.getAttribute('data-for');
          const field = this.form.querySelector(`[name="${fieldName}"]`) as HTMLElement;
          field?.focus();
        }
        return;
      }

      // Show loading state
      this.submitBtn.disabled = true;
      this.submitIcon.classList.add('hidden');
      this.submitText.textContent = 'Отправка...';
      this.submitSpinner.classList.remove('hidden');
      this.statusEl.classList.add('hidden');

      const formData = new FormData(this.form);
      const data = {
        name: (formData.get('name') as string).trim(),
        phone: (formData.get('phone') as string).trim(),
        service: formData.get('service') as string,
        barber: formData.get('barber') as string || 'Любой',
        date: formData.get('date') as string,
        time: formData.get('time') as string,
        message: (formData.get('message') as string || '').trim(),
      };

      try {
        const response = await fetch('/vegas-barbershop/api/booking', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (response.ok && result.success) {
          this.showSuccess('Заявка отправлена! Перенаправляем...');
          this.submitText.textContent = '✓ Отправлено!';

          // Redirect to thank-you page after 1.5s on success
          setTimeout(() => {
            window.location.href = '/vegas-barbershop/thanks';
          }, 1500);
        } else {
          this.showError(result.error || 'Произошла ошибка при отправке');
          this.resetButton();
        }
      } catch (err) {
        this.showError('Ошибка соединения. Проверьте подключение к интернету.');
        this.resetButton();
      }
    }

    showError(message: string) {
      this.statusEl.textContent = '✗ ' + message;
      this.statusEl.classList.remove('hidden', 'text-success');
      this.statusEl.classList.add('text-error');
    }

    showSuccess(message: string) {
      this.statusEl.textContent = '✓ ' + message;
      this.statusEl.classList.remove('hidden', 'text-error');
      this.statusEl.classList.add('text-success');
    }

    resetButton() {
      this.submitBtn.disabled = false;
      this.submitIcon.classList.remove('hidden');
      this.submitText.textContent = 'Записаться';
      this.submitSpinner.classList.add('hidden');
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => new BookingFormHandler());
  } else {
    new BookingFormHandler();
  }
</script>
