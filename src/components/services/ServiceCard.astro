---
import type { Service } from './services.data';

export interface Props {
  service: Service;
  index: number;
}

const { service, index } = Astro.props;
const delayClass = `reveal-delay-${(index % 5) + 1}`;
---

<article class={`bg-brand-surface border border-brand-dark rounded-[8px] p-6 transition-all duration-300 hover:border-brand-gold hover:shadow-md group relative reveal ${delayClass}`}>
  <!-- Hit Badge -->
  {service.hit && (
    <div class="absolute -top-2 -right-2 z-10 px-2.5 py-0.5 rounded-full bg-error text-brand-white text-[0.675rem] font-semibold tracking-[0.08em] shadow-sm">
      🔥 Хит
    </div>
  )}

  <div class="flex items-start gap-4">
    <!-- Icon -->
    <div class="shrink-0 w-8 h-8 text-brand-gold mt-1">
      {
        service.icon === 'scissors' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>
        )
      }
      {
        service.icon === 'shower-head' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4 L20 20"/><path d="M20 4 L4 20"/><circle cx="12" cy="12" r="8"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="M2 12h4"/><path d="M18 12h4"/></svg>
        )
      }
      {
        service.icon === 'spray-can' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3 L21 21"/><path d="M5 8 L11 8"/><rect x="5" y="8" width="6" height="4" rx="1"/><rect x="3" y="12" width="18" height="8" rx="2"/></svg>
        )
      }
      {
        service.icon === 'rail-symbol' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20 L20 4"/><path d="M4 4 L20 20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
        )
      }
      {
        service.icon === 'sparkles' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/><path d="M20 3v4"/><path d="M22 5h-4"/></svg>
        )
      }
      {
        service.icon === 'palette' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r="0.5"/><circle cx="17.5" cy="10.5" r="0.5"/><circle cx="8.5" cy="7.5" r="0.5"/><circle cx="6.5" cy="12.5" r="0.5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.93 0 1.5-.5 1.5-1.5 0-.3-.1-.6-.4-.9-.5-.5-.7-1.2-.4-1.8.4-.8 1.2-1.3 2-1.3h1.3c4.4 0 8-3.6 8-8 0-4.4-3.6-8-8-8z"/></svg>
        )
      }
      {
        service.icon === 'wind' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>
        )
      }
    </div>

    <!-- Content -->
    <div class="flex-1 min-w-0">
      <h3 class="font-heading text-[clamp(1.125rem,1.5vw,1.25rem)] font-semibold text-brand-white mb-1">
        {service.name}
      </h3>
      <p class="font-body text-[clamp(0.75rem,0.9vw,0.825rem)] text-brand-gray mb-3 leading-relaxed">
        {service.description}
      </p>
      <div class="flex items-center justify-between">
        <span class="text-brand-gold font-body text-[1.25rem] font-bold">{service.price.toLocaleString('ru-RU')} ₽</span>
        <time datetime={service.duration + 'M'} class="flex items-center gap-1.5 text-brand-gray font-body text-[0.8rem]">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {service.duration} мин
        </time>
      </div>
    </div>
  </div>
</article>
